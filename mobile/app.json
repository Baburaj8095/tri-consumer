{
  "expo": {
    "name": "Tri Shopping",
    "slug": "mobile",
    "scheme": "trikonekt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Trikonekt uses your location to show nearby stores and calculate delivery availability.",
        "NSCameraUsageDescription": "Trikonekt uses the camera to scan merchant and service QR codes.",
        "LSApplicationQueriesSchemes": [
          "upi",
          "gpay",
          "phonepe",
          "paytmmp"
        ]
      }
    },
    "android": {
      "package": "com.trikonekt.consumer",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Trikonekt to use your location for nearby stores and delivery."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Trikonekt to scan QR codes."
        }
      ],
      "expo-notifications",
      "./plugins/withAndroidUpiQueries",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "10518675-b95b-4552-af72-b6adff37a603"
      }
    },
    "owner": "baburaj8095"
  }
}
